#!/bin/bash
# ============================================
# CTF 部署统一配置文件
# ============================================

# --- 路径 ---
ISO_PATH="/var/lib/libvirt/images/ubuntu-20.04.6-live-server-amd64.iso"
WORK_DIR="/var/lib/libvirt/ctf-build"
EXPORT_DIR="/export/ctf-vms"
PROJECT_DIR="E:/vibecoding/gdj_ctf"

# --- 网桥名称 ---
BR_EXT="br0"       # 外部网络 (桥接物理网卡)
BR_A="br-a"        # 场景A隔离网络
BR_B="br-b"        # 场景B隔离网络
BR_C="br-c"        # 场景C隔离网络

# --- 场景内网段 ---
SUBNET_A="192.168.100.0/24"
SUBNET_B="192.168.110.0/24"
SUBNET_C="192.168.120.0/24"

# --- VM资源配置 ---
VM_DISK=15G
VM_RAM_DMZ=2048       # MB
VM_RAM_INTERNAL=4096  # MB (Java服务需要更多内存)
VM_VCPU_DMZ=1
VM_VCPU_INTERNAL=2

# --- 通用密码 ---
MYSQL_ROOT_PASS="R00t@Mysql#2024"

# --- VM网络分配 ---
declare -A VM_IPS
VM_IPS[a1_ext]="dhcp"
VM_IPS[a1_int]="192.168.100.1/24"
VM_IPS[a2]="192.168.100.2/24"
VM_IPS[b1_ext]="dhcp"
VM_IPS[b1_int]="192.168.110.1/24"
VM_IPS[b2]="192.168.110.2/24"
VM_IPS[c1_ext]="dhcp"
VM_IPS[c1_int]="192.168.120.1/24"
VM_IPS[c2]="192.168.120.2/24"

# --- Host内网IP (用于访问Internal VM) ---
HOST_A="192.168.100.254/24"
HOST_B="192.168.110.254/24"
HOST_C="192.168.120.254/24"

# --- 部署顺序 (Internal先部署，DMZ后部署) ---
VM_ORDER=("a2" "c2" "b2" "a1" "c1" "b1")
